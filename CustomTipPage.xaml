<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TipCalculator.CustomTipPage"
             Title="Custom Tip">

    <Grid x:Name="LayoutRoot" BackgroundColor="{DynamicResource bgColor}" Padding="10"
          ColumnDefinitions="Auto, *"
          RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto">

        <Label x:Name="billLabel" Text="Bill" Style="{StaticResource infoLabelStyle}" TextColor="{DynamicResource fgColor}" VerticalOptions="Center" />
        <Entry x:Name="billInput" Placeholder="Enter Amount" Keyboard="Numeric" Grid.Column="1" />

        <Label Text="Tip" Style="{StaticResource infoLabelStyle}" TextColor="{DynamicResource fgColor}" Grid.Row="1" VerticalOptions="Center" />
        <Label x:Name="tipOutput" Text="0.00" Style="{StaticResource baseLabelStyle}" TextColor="{DynamicResource fgColor}" Grid.Row="1" Grid.Column="1" />

        <Label Text="Total" Style="{StaticResource infoLabelStyle}" TextColor="{DynamicResource fgColor}" Grid.Row="2" VerticalOptions="Center" />
        <Label x:Name="totalOutput" Text="0.00" Style="{StaticResource baseLabelStyle}" TextColor="{DynamicResource fgColor}" Grid.Row="2" Grid.Column="1" />

        <Label x:Name="tipPercentLabel" Text="Tip Percentage" Style="{StaticResource infoLabelStyle}" TextColor="{DynamicResource fgColor}" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,20,0,0" />

        <Slider x:Name="tipPercentSlider" Minimum="0" Maximum="100" Value="15" Grid.Row="4" Grid.ColumnSpan="2" />

        <HorizontalStackLayout Grid.Row="5" Grid.ColumnSpan="2" Spacing="10" HorizontalOptions="Center">
            <Button Text="15%" Clicked="OnNormalTip" WidthRequest="100" />
            <Button Text="20%" Clicked="OnGenerousTip" WidthRequest="100" />
        </HorizontalStackLayout>

        <HorizontalStackLayout Grid.Row="6" Grid.ColumnSpan="2" Spacing="10" HorizontalOptions="Center" Margin="0,20,0,0">
            <Button x:Name="roundDown" Text="Round Down" Clicked="OnRoundDown" WidthRequest="150" />
            <Button x:Name="roundUp" Text="Round Up" Clicked="OnRoundUp" WidthRequest="150" />
        </HorizontalStackLayout>

    </Grid>
</ContentPage>
